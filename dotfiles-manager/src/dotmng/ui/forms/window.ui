       <property name="styleSheet">
        <string notr="true">/* ESTILOS PARA BOTON PRINCIPAL */
QPushButton#unknown_update {
    background-color: #2563eb;
    color: #ffffff;
    border: 1px solid #1d4ed8;
	padding-right: 3px;
	border-radius: 8px;
}

QPushButton#unknown_update:hover {
    background-color: #1d4ed8;
}

QPushButton#unknown_update:pressed {
    background-color: #2563eb;
}

QPushButton#discovery_apps {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 5px 10px;
    background-color: #ffffff;
    color: #475569;
    min-width: 150px;
}

QPushButton#discovery_apps:hover {
    border: 1px solid #2563eb;
}

QPushButton#discovery_apps:pressed {
    background-color: #f8faff;
}

QPushButton#discovery_apps:disabled {
    background-color: #f1f5f9;
    color: #94a3b8;
    border: 1px solid #e2e8f0;
}

QFrame#widgetUnknown {
    border: 1px solid #e2e8f0;
    border-top-right-radius: 8px;
    border-top-left-radius: 8px;
    background-color: #ffffff;
    color: #475569;
}

QFrame#stats_unknown {
	border-bottom: 1px solid #e2e8f0;
    border-top-right-radius: 8px;
    border-top-left-radius: 8px;
    background-color: #ffffff;
	padding-right: 5px;
    color: #475569;
}

/* ESTILOS TOGGLE APPS */
QPushButton#switch:checked,
QPushButton#switch:pressed {
	background-color: transparent;
    border: none;
}</string>
