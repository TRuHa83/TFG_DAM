                    <property name="styleSheet">
                     <string notr="true">/* Estilo base para todos los LineEdit */
QLineEdit {
    background-color: #f8faff;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    color: #475569;
    font-family: &quot;JetBrains Mono&quot;, &quot;Consolas&quot;, monospace; /* Ideal para URLs/Paths */
    selection-background-color: #cbd5e1;
}

/* Estado: Cuando se activa para editar y el usuario hace clic (Focus) */
QLineEdit:focus {
    background-color: #ffffff;
    border: 1px solid #2563eb; /* Tu azul principal */
    color: #1e293b;
}

/* Opcional: Si lo deshabilitas por completo en lugar de ReadOnly */
QLineEdit:disabled {
    background-color: #f1f5f9;
    color: #ABABAB;
    border: 1px solid #e2e8f0;
}</string>
